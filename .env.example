# GHL (GoHighLevel) — Required
GHL_API_TOKEN=your_ghl_private_integration_token
GHL_LOCATION_ID=your_ghl_location_id

# Tracking — Optional (leave blank to disable)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=000000000000

# GHL Community URL — link for "Enter the Victor Challenge" buttons
NEXT_PUBLIC_GHL_COMMUNITY_URL=https://your-community-url-here
